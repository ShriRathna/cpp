#include<iostream>
using namespace std;
template<class TT>
class Matrix
{
   TT M[2][2];
   public:
   void get()
   {
      cout<<"enter values:";
      for(int i=0;i<2;i++)
      {
         for(int j=0;j<2;j++)
         {
            cin>>M[i][j];
         }
      }
   }
   void display()
   {
      cout<<"matrix:"<<endl;
      for(int i=0;i<2;i++)
      {
         for(int j=0;j<2;j++)
         {
            cout<<M[i][j]<<" ";
         }
         cout<<endl;
      }
   }
   Matrix add(Matrix<TT> x)
   {
      Matrix<TT> T;
      for(int i=0;i<2;i++)
      {
         for(int j=0;j<2;j++)
         {
            T.M[i][j]=M[i][j]+x.M[i][j];
         }
      }
      return T;
   }
   Matrix operator *(Matrix<TT> x)
   {
      Matrix<TT> T;
      for(int i=0;i<2;i++)
      {
         for(int j=0;j<2;j++)
         {
            T.M[i][j]=0;
            for(int k=0;k<2;k++)
            {
               T.M[i][j]=M[i][k]*x.M[k][i];
            }
         }
      }
      return T;
   }
};
int main()
{
   Matrix<int> M1,M2,M3;
   M1.get();
   M2.get();
   M3=M1.add(M2);
   M3.display();
   Matrix<float> M4,M5,M6;
   M4.get();
   M5.get();
   M6=M4*M5;
   M6.display();
}
