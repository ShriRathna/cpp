#include<iostream>
using namespace std;
class Octal
{
   private:
      int oct[100],l,d;
   public:
      void display()
      {
         cout<<"d ="<<d<<"   ";
         for(int i=l-1;i>=0;i--)
         {
            cout<<oct[i]<<"   ";
         }
      }
      void operator =(int no)
      {
         d=no;
         int i=0;
         while (no!=0)
         {
            oct[i]=no%8;
            no=no/8;
            i++;
         }
         l=i;
      }
      Octal operator +(Octal x)
      {
         Octal R;
         int z=d+x.d;
         R=z;
         return R;
      }
};
int main()
{
   Octal O1,O2,O3;
   int n1,n2;
   cout<<"enter n1,n2:";
   cin>>n1>>n2;
   O1=n1;
   O2=n2;
   O3=O1+O2;
   O1.display();
   O2.display();
   O3.display();
}
