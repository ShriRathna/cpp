#include<iostream>
using namespace std;
class Inventory
{
   private:
      int code;
      float price;
   public:
      void get()
      {
         cout<<"enter product code:";
         cin>>code;
         cout<<"enter product price:";
         cin>>price;
      }
      void display()
      {
         cout<<"product code:"<<code<<endl;
         cout<<"product price:"<<price<<endl;
      }
};
int main()
{
   Inventory p1[2];
   for(int i=0;i<2;i++)
   {
      p1[i].get();
      p1[i].display();
   }
   return 0;
}
