#include<iostream>
#include<string.h>
using namespace std;
class Str
{
   private:
      char *name;
      int l;
   public:
      Str()
      {
         l=0;
         name=NULL;
      }
      Str(const char a[])
      {
         l=strlen(a);
         name=new char[l+1];
         strcpy(name,a);
      }
      Str(const char a[],const char aa[])
      {
         int l1=strlen(a);
         int l2=strlen(aa);
         l=l1+l2;
         name=new char[l+1];
         strcpy(name,a);
         strcat(name,aa);
      }
      void display()
      {
         cout<<name<<endl;
      }
};
int main()
{
   Str S("EEE");
   Str SS("Welcome","EEE");
   S.display();
   SS.display();
}
