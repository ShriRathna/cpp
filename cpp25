#include<iostream>
using namespace std;
class base
{
   public:
      virtual void display()
      {
         cout<<"class base"<<endl;
      }
};
class A:public base
{
   public:
      void display()
      {
         cout<<"class A"<<endl;
      }
};
class B:public A
{
   public:
      void display()
      {
         cout<<"class B"<<endl;
      }
};
class C:public B
{
   public:
      void display()
      {
         cout<<"class c"<<endl;
      }
};
class D:public C
{
   public:
      void display()
      {
         cout<<"class D"<<endl;
      }
};
class E:public D
{
   public:
      void display()
      {
         cout<<"class E"<<endl;
      }
};
int main()
{
   base *p;
   base BB;
   p= &BB;
   p->display();
   A aa;
   p=&aa;
   p->display();
   B bb;
   p=&bb;
   p->display();
   C cc;
   p=&cc;
   p->display();
   D dd;
   p=&dd;
   p->display();
   E ee;
   p=&ee;
   p->display();
}
